{
    "version": 2,
    "environment": {
        "APP_NAME": "Liphium",
        "LISTEN": "0.0.0.0",
        "TESTING": "true"
    },
    "databases": [
        {
            "type": "postgresql",
            "name": "main",
            "mappings": {
                "username": "DB_USER",
                "password": "DB_PASSWORD",
                "database": "DB_DATABASE",
                "host": "DB_HOST",
                "port": "DB_PORT"
            }
        },
        {
            "type": "postgresql",
            "name": "chat",
            "mappings": {
                "username": "CN_DB_USER",
                "password": "CN_DB_PASSWORD",
                "database": "CN_DB_DATABASE",
                "host": "CN_DB_HOST",
                "port": "CN_DB_PORT"
            }
        }
    ]
}