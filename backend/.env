ENV=LOCAL

# Default ports and addresses
MAGIC_PROTOCOL=http://
MAGIC_DOMAIN=127.0.0.1
MAGIC_LISTEN=127.0.0.1
MAGIC_PORT=8080
TEMPL_PROXY_PORT=8081
# ^ this port is for development only

# Magic options (CHANGE THESE IN PRODUCTION)
MAGIC_TESTING=true
MAGIC_LOCAL=true # NEVER TURN THIS ON IN PRODUCTION (IT MAKES YOUR SERVER VULNERABLE)
MAGIC_SKIP_AUTH=true # NEVER TURN THIS ON IN PRODUCTION (IT MAKES YOUR SERVER VULNERABLE)

# Magic JWT secret (make secure in prod)
MAGIC_JWT_SECRET=hello

# Magic postgres credentials (put these into secret.env)
# MAGIC_DB_HOST=localhost
# MAGIC_DB_USERNAME=postgres
# MAGIC_DB_PASSWORD=some_pass
# MAGIC_DB_NAME=database
# MAGIC_DB_PORT=5432

# Magic GitHub App
# MAGIC_GH_APPSLUG=liphium-magic
# MAGIC_GH_APP=10023
# MAGIC_GH_CLIENT=client_id
# MAGIC_GH_SECRET=secret

# Magic Hetzner Integration
# MAGIC_HETZNER=your_token