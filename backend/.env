ENV=LOCAL

# Default ports
MAGIC_LISTEN=127.0.0.1
MAGIC_PORT=8080
TEMPL_PROXY_PORT=8081
# ^ this port is for development only

# Magic default user account (CHANGE THESE IN PRODUCTION)
MAGIC_SKIP_AUTH=true # NEVER TURN THIS ON IN PRODUCTION (IT MAKES YOUR SERVER VULNERABLE)
MAGIC_DEFAULT_USERNAME=admin

# Magic postgres credentials (put these into secret.env)
# MAGIC_DB_HOST=localhost
# MAGIC_DB_USERNAME=postgres
# MAGIC_DB_PASSWORD=some_pass
# MAGIC_DB_NAME=database
# MAGIC_DB_PORT=5432

# Magic GitHub App
MAGIC_GH_CALLBACK=http://127.0.0.1:8081/auth/gh/callback
# MAGIC_GH_CLIENT=client_id
# MAGIC_GH_SECRET=secret