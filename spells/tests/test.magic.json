{
    "version": 1,
    "caster": "docker",
    "environment": {
        "JWT_SECRET": "%jwt_secret%"
    },
    "ports": {
        "3000": "http",
        "3001": "http",
        "3002": "http"
    },
    "databases": [
        {
            "type": "postgresql",
            "name": "main",
            "mappings": {
                "username": "DB_USER",
                "password": "DB_PASSWORD",
                "database": "DB_DATABASE",
                "host": "DB_HOST",
                "port": "DB_PORT"
            }
        }
    ]
}